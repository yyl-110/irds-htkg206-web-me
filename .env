# 标题
VITE_APP_TITLE=4.0前端框架

# 项目本地运行端口号
VITE_PORT=5173

# open 运行 npm run dev 时自动打开浏览器
VITE_OPEN=true

# 租户开关
VITE_APP_TENANT_ENABLE=true

# 验证码的开关
VITE_APP_CAPTCHA_ENABLE=false

# 请求头中的 token 值前缀
VITE_TOKEN_HEADER_PREFIX='CirPoint '

# 菜单栏是否显示在顶部(默认显示在左侧), 'top' | 'left'
VITE_APP_MENU_POSITION='left'

# iconify 图标使用内网代理的地址
VITE_APP_ICONIFY_RESOURCES=/iconify
#  VITE_BASE_PREVIEW_URL='http://10.190.113.233:31016'
VITE_BASE_PREVIEW_URL='/Api'

